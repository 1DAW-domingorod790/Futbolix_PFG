APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=futbolix
DB_USERNAME=futbolix
DB_PASSWORD=futbolix

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_ENCRYPTION=tls
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

FOOTBALL_DATA_ORG_API_KEY=
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.4
GROQ_MAX_COMPLETION_TOKENS=900
GROQ_REASONING_EFFORT=
GROQ_TIMEOUT_SECONDS=30
FUTBOLIX_AI_INCLUDE_CONVERSATION_HISTORY=false
FUTBOLIX_AI_MAX_CONTEXT_MESSAGES=2
FUTBOLIX_AI_MAX_MESSAGE_CONTEXT_CHARS=800
FUTBOLIX_AI_MAX_SYSTEM_CONTEXT_CHARS=30000
FUTBOLIX_AI_MAX_COMPETITIONS_CONTEXT=5
FUTBOLIX_AI_MAX_STANDINGS_CONTEXT=25
FUTBOLIX_AI_MAX_COMPETITION_GAMES_CONTEXT=30
FUTBOLIX_AI_MAX_TEAMS_CONTEXT=8
FUTBOLIX_AI_MAX_TEAM_GAMES_CONTEXT=80
FUTBOLIX_AI_WEB_SEARCH_ENABLED=false
FUTBOLIX_AI_WEB_SEARCH_TOOL=browser_search
FUTBOLIX_AI_WEB_SEARCH_TOOL_CHOICE=auto
FUTBOLIX_AI_TOKENS_PER_CREDIT=750
FUTBOLIX_AI_MINIMUM_CREDITS_PER_MESSAGE=1
FUTBOLIX_AI_MAXIMUM_CREDITS_PER_MESSAGE=5
FUTBOLIX_AI_ESTIMATED_TOKENS_PER_MESSAGE=600
FUTBOLIX_AI_FREE_CREDITS=50
FUTBOLIX_AI_PRO_CREDITS=500
